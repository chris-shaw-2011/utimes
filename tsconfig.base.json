{
	"compilerOptions": {
		"target": "ES2022",
		"lib": ["ES2022"],
		"module": "nodenext",
		"strict": true,
		"verbatimModuleSyntax": true,
		"forceConsistentCasingInFileNames": true,
		"noEmitOnError": true,
		"noImplicitReturns": true,
		"noUncheckedIndexedAccess": true,
		"exactOptionalPropertyTypes": true,
		"skipLibCheck": true,
		"newLine": "lf"
	}
}
