{
	"extends": "./tsconfig.base.json",
	"compilerOptions": {
		"rootDir": "src",
		"outDir": "dist",
		"types": ["node"],
		"declaration": true,
		"declarationMap": true,
		"sourceMap": true,
		"stripInternal": true
	},
	"include": ["src/**/*.ts"],
	"exclude": ["dist", "lib", "node_modules", "tests"]
}
